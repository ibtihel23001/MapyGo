// ============================================================
// Prisma Schema — Travel Agency SaaS
// Run: npx prisma db push   (apply to existing DB)
//  or: npx prisma migrate dev --name init  (fresh migration)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Roles ───────────────────────────────────────────────────
model Role {
  id          Int      @id @default(autoincrement())
  name        String  
  slug        String   @unique
  description String? 
  createdAt   DateTime @default(now()) @map("created_at")

  users User[]

  @@map("roles")
}

// ─── Users ───────────────────────────────────────────────────
model User {
  id               Int       @id @default(autoincrement())
  roleId           Int       @map("role_id")
  agencyId         Int?      @map("agency_id")
  username         String    @unique
  email            String    @unique
  password         String   
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  phone            String?  
  avatar           String?  
  isActive         Boolean   @default(true) @map("is_active")
  emailVerified    Boolean   @default(false) @map("email_verified")
  emailVerifyToken String?   @map("email_verify_token")
  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  lastLogin        DateTime? @map("last_login")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  role   Role    @relation(fields: [roleId], references: [id])
  agency Agency? @relation(fields: [agencyId], references: [id])

  requestedRefunds  Refund[]       @relation("RequestedBy")
  processedRefunds  Refund[]       @relation("ProcessedBy")
  createdTransactions Transaction[] @relation("CreatedBy")
  createdSubs       Subscription[] @relation("CreatedBy")
  activityLogs      ActivityLog[]
  notifications     Notification[]
  generatedReports  Report[]

  @@map("users")
}

// ─── Agencies ────────────────────────────────────────────────
model Agency {
  id             Int          @id @default(autoincrement())
  name           String      
  slug           String       @unique
  email          String      
  phone          String?     
  address        String?     
  city           String?     
  country        String?     
  logo           String?     
  website        String?     
  licenseNumber  String?      @map("license_number")
  status         AgencyStatus @default(pending)
  registeredBy   Int?         @map("registered_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  users         User[]
  subscriptions Subscription[]
  tickets       Ticket[]
  refunds       Refund[]
  transactions  Transaction[]
  apiConfig     AgencyApiConfig?
  sellers       Seller[]
  clients       Client[]
  notifications Notification[]
  reports       Report[]

  @@map("agencies")
}

enum AgencyStatus {
  pending
  active
  suspended
  inactive
}

// ─── Subscriptions ───────────────────────────────────────────
model Subscription {
  id               Int                @id @default(autoincrement())
  agencyId         Int                @map("agency_id")
  planName         String             @default("Annual Plan") @map("plan_name")
  price            Decimal            @default(0.00)
  currency         String             @default("USD")
  startDate        DateTime           @map("start_date")
  endDate          DateTime           @map("end_date")
  status           SubscriptionStatus @default(active)
  paymentMethod    String?            @map("payment_method")
  paymentReference String?            @map("payment_reference")
  notes            String?           
  createdById      Int?               @map("created_by")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  agency    Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("CreatedBy", fields: [createdById], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  active
  expired
  cancelled
  pending
}

// ─── Tickets ─────────────────────────────────────────────────
model Ticket {
  id            Int          @id @default(autoincrement())
  agencyId      Int          @map("agency_id")
  ticketNumber  String       @unique @map("ticket_number")
  pnr           String?
  passengerName String       @map("passenger_name")
  dateOfIssue   DateTime?    @map("date_of_issue")
  departureDate DateTime?    @map("departure_date")
  arrivalDate   DateTime?    @map("arrival_date")
  airFare       Decimal?     @map("air_fare")
  ttc           Decimal?
  status        TicketStatus @default(pending)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  agency       Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  refunds      Refund[]
  transactions Transaction[]

  @@map("tickets")
}

enum TicketStatus {
  pending
  approved
  rejected
  refund
}

// ─── Refunds ─────────────────────────────────────────────────
model Refund {
  id            Int          @id @default(autoincrement())
  agencyId      Int          @map("agency_id")
  ticketId      Int?         @map("ticket_id")
  ticketNumber  String?      @map("ticket_number")
  passengerName String       @map("passenger_name")
  reason        String      
  refundAmount  Decimal      @map("refund_amount")
  currency      String?      @default("USD")
  status        RefundStatus @default(pending)
  requestedById Int?         @map("requested_by")
  processedById Int?         @map("processed_by")
  processedAt   DateTime?    @map("processed_at")
  notes         String?     
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  agency      Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  ticket      Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  requestedBy User?   @relation("RequestedBy", fields: [requestedById], references: [id])
  processedBy User?   @relation("ProcessedBy", fields: [processedById], references: [id])

  transactions Transaction[]

  @@map("refunds")
}

enum RefundStatus {
  pending
  approved
  rejected
  processed
}

// ─── Transactions ────────────────────────────────────────────
model Transaction {
  id              Int             @id @default(autoincrement())
  agencyId        Int             @map("agency_id")
  type            TransactionType
  category        String?        
  description     String         
  amount          Decimal        
  currency        String          @default("USD")
  reference       String?        
  ticketId        Int?            @map("ticket_id")
  refundId        Int?            @map("refund_id")
  createdById     Int?            @map("created_by")
  transactionDate DateTime        @map("transaction_date")
  createdAt       DateTime        @default(now()) @map("created_at")

  agency    Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  ticket    Ticket? @relation(fields: [ticketId], references: [id])
  refund    Refund? @relation(fields: [refundId], references: [id])
  createdBy User?   @relation("CreatedBy", fields: [createdById], references: [id])

  @@map("transactions")
}

enum TransactionType {
  revenue
  expense
  refund
  commission
}

// ─── Agency API Config ────────────────────────────────────────
model AgencyApiConfig {
  id           Int       @id @default(autoincrement())
  agencyId     Int       @unique @map("agency_id")
  emailAddress String    @map("email_address")
  emailPassword String   @map("email_password")
  imapHost     String    @default("imap.gmail.com") @map("imap_host")
  imapPort     Int       @default(993) @map("imap_port")
  isActive     Boolean   @default(true) @map("is_active")
  lastSync     DateTime? @map("last_sync")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("agency_api_config")
}

// ─── Sellers ─────────────────────────────────────────────────
model Seller {
  id        Int      @id @default(autoincrement())
  agencyId  Int      @map("agency_id")
  name      String  
  email     String? 
  phone     String? 
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("sellers")
}

// ─── Clients ─────────────────────────────────────────────────
model Client {
  id             Int      @id @default(autoincrement())
  agencyId       Int      @map("agency_id")
  name           String  
  email          String? 
  phone          String? 
  passportNumber String?  @map("passport_number")
  nationality    String? 
  createdAt      DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("clients")
}

// ─── Notifications ───────────────────────────────────────────
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  agencyId  Int?     @map("agency_id")
  type      String  
  title     String  
  message   String  
  isRead    Boolean  @default(false) @map("is_read")
  link      String? 
  createdAt DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id])
  agency Agency? @relation(fields: [agencyId], references: [id])

  @@map("notifications")
}

// ─── Activity Logs ───────────────────────────────────────────
model ActivityLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  agencyId    Int?     @map("agency_id")
  action      String  
  description String? 
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// ─── Agency Registrations ────────────────────────────────────
model AgencyRegistration {
  id            Int                @id @default(autoincrement())
  agencyName    String             @map("agency_name")
  contactName   String             @map("contact_name")
  email         String            
  phone         String?           
  address       String?           
  city          String?           
  country       String?           
  licenseNumber String?            @map("license_number")
  message       String?           
  status        RegistrationStatus @default(pending)
  reviewedBy    Int?               @map("reviewed_by")
  reviewedAt    DateTime?          @map("reviewed_at")
  createdAt     DateTime           @default(now()) @map("created_at")

  @@map("agency_registrations")
}

enum RegistrationStatus {
  pending
  approved
  rejected
}

// ─── Reports ─────────────────────────────────────────────────
model Report {
  id          Int      @id @default(autoincrement())
  agencyId    Int      @map("agency_id")
  type        String  
  title       String  
  periodStart DateTime? @map("period_start")
  periodEnd   DateTime? @map("period_end")
  filePath    String?  @map("file_path")
  generatedBy Int?     @map("generated_by")
  createdAt   DateTime @default(now()) @map("created_at")

  agency    Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  generator User?  @relation(fields: [generatedBy], references: [id])

  @@map("reports")
}
